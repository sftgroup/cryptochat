generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  address     String   @unique
  ensName     String?
  avatarUrl   String?
  displayName String?
  bio         String?
  publicKey   String?  // ECDH P-256 public key JWK for E2EE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions    Session[]
  contacts    Contact[]  @relation("UserContacts")
  contactOf   Contact[]  @relation("ContactOf")
  groupMembers GroupMember[]
  createdGroups Group[]  @relation("GroupCreator")

  @@index([address])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  token        String   @unique
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model Nonce {
  id        String   @id @default(uuid())
  address   String
  nonce     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([address, nonce])
}

model Contact {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation("UserContacts", fields: [userId], references: [id])
  contactId  String
  contact    User     @relation("ContactOf", fields: [contactId], references: [id])
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  @@unique([userId, contactId])
  @@index([userId])
  @@index([contactId])
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  messageType String  @default("text")
  metadata   String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([senderId, receiverId])
  @@index([receiverId, createdAt])
}

// Group chat
model Group {
  id          String   @id @default(uuid())
  name        String
  description String?
  avatarUrl   String?
  xmtpGroupId String?  // XMTP group conversation ID (after creation)
  creatorId   String
  creator     User     @relation("GroupCreator", fields: [creatorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     GroupMember[]
  messages    GroupMessage[]

  @@index([xmtpGroupId])
}

model GroupMember {
  id        String   @id @default(uuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      String   @default("member") // admin, member
  joinedAt  DateTime @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

model GroupMessage {
  id          String   @id @default(uuid())
  groupId     String
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderId    String
  content     String
  messageType String   @default("text")
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([groupId, createdAt])
}
